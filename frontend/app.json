{
  "expo": {
    "name": "Soulsync",
    "slug": "soulsync-mood",
    "version": "1.2.2",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "myapp",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "buildNumber": "10202"
    },
    "android": {
      "package": "com.raeduslabs.soulsync",
      "versionCode": 10202,
      "softwareKeyboardLayoutMode": "resize",
      "permissions": [
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.SCHEDULE_EXACT_ALARM"
      ],
      "blockedPermissions": [
        "android.permission.RECORD_AUDIO"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#ffffff"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      "expo-sqlite",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#4CAF50",
          "defaultChannel": "daily-reminder"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "SoulSync lets you attach photos to your mood entries. Your photos stay on this device.",
          "cameraPermission": "SoulSync lets you take photos to attach to your mood entries. Your photos stay on this device."
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "enableProguardInReleaseBuilds": true,
            "enableShrinkResourcesInReleaseBuilds": true
          }
        }
      ],
      "./plugins/withReleaseAbis"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "0a8c145e-223a-4f29-9c26-4a1a5205db66"
      }
    },
    "owner": "astraedus"
  }
}
